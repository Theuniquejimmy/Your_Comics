        self.ai_btn.setEnabled(True)
        self.skip_btn.setEnabled(True)
        self.remote_cover_label.setText(f"Error:\n{error_msg}")
        
        # Turn the Accept button back on if they already had a Comic Vine item selected
        if self.results_list.currentItem():
            self.accept_btn.setEnabled(True)
        
class ComicConverterThread(QThread):
    finished_conversion = pyqtSignal(bool, str, str)
    progress_update = pyqtSignal(int, int) 
    status_update = pyqtSignal(str)        

    def __init__(self, file_path, xml_string):
        super().__init__()
        self.file_path = file_path
        self.xml_string = xml_string

    def run(self):
        import os, zipfile, tempfile
        try:
            dir_name = os.path.dirname(self.file_path)
            base_name, ext = os.path.splitext(os.path.basename(self.file_path))
            new_cbz_path = os.path.join(dir_name, base_name + ".cbz")

            # ========================================================
            # THE LIGHTNING CBZ PATH (No hard drive extraction!)
            # ========================================================
            if ext.lower() == '.cbz':
                has_xml = False
                try:
                    with zipfile.ZipFile(self.file_path, 'r') as zf:
                        if any(f.lower() == 'comicinfo.xml' for f in zf.namelist()):
                            has_xml = True
                except Exception: pass
                
                # SCENARIO A: No XML exists. Just slap it in instantly!
                if not has_xml and self.xml_string:
                    self.status_update.emit("Appending metadata instantly...")
                    with zipfile.ZipFile(self.file_path, 'a', zipfile.ZIP_DEFLATED) as zf:
                        zf.writestr('ComicInfo.xml', self.xml_string.encode('utf-8'))
                    self.finished_conversion.emit(True, "Metadata injected instantly!", self.file_path)
                    return 
                    
                # SCENARIO B: XML already exists. We MUST rewrite the zip to prevent duplicates.
                # But we do it in an instant memory stream, skipping the hard drive!
                if has_xml and self.xml_string:
                    self.status_update.emit("Updating metadata (Fast Stream)...")
                    temp_path = self.file_path + ".tmp"
                    
                    with zipfile.ZipFile(self.file_path, 'r') as zin:
                        infolist = zin.infolist()
                        total_files = len(infolist)
                        with zipfile.ZipFile(temp_path, 'w', zipfile.ZIP_DEFLATED) as zout:
                            for i, item in enumerate(infolist):
                                if item.filename.lower() != 'comicinfo.xml':
                                    zout.writestr(item, zin.read(item.filename))
                                self.progress_update.emit(i + 1, total_files)
                                
                            # Inject the brand new XML at the very end
                            zout.writestr('ComicInfo.xml', self.xml_string.encode('utf-8'))
                            
                    os.replace(temp_path, self.file_path)
                    self.finished_conversion.emit(True, "Metadata updated instantly!", self.file_path)
                    return

            # ========================================================
            # THE CBR TO CBZ CONVERSION PATH (Requires Extraction)
            # ========================================================
            with tempfile.TemporaryDirectory() as temp_dir:
                self.status_update.emit("Extracting CBR archive...")
                
                if ext.lower() == '.cbr':
                    try:
                        import rarfile
                        with rarfile.RarFile(self.file_path, 'r') as rf:
                            files = rf.infolist()
                            for i, f in enumerate(files):
                                rf.extract(f, temp_dir)
                                self.progress_update.emit(i + 1, len(files))
                    except Exception:
                        # Fallback to patoolib if rarfile is missing or fails
                        import patoolib
                        patoolib.extract_archive(self.file_path, outdir=temp_dir, interactive=False)
                else:
                    self.finished_conversion.emit(False, "Unsupported format.", "")
                    return

                if self.xml_string:
                    self.status_update.emit("Generating metadata...")
                    xml_path = os.path.join(temp_dir, 'ComicInfo.xml')
                    with open(xml_path, 'w', encoding='utf-8') as f:
                        f.write(self.xml_string)

                self.status_update.emit("Creating new CBZ...")
                temp_cbz = new_cbz_path + ".tmp"
                
                all_files = []
                for root, _, files in os.walk(temp_dir):
                    for file in files:
                        if file.lower() == 'comicinfo.xml' and root != temp_dir:
                            continue
                        all_files.append(os.path.join(root, file))

                with zipfile.ZipFile(temp_cbz, 'w', zipfile.ZIP_DEFLATED) as zf:
                    for i, full_path in enumerate(all_files):
                        arcname = os.path.relpath(full_path, temp_dir) 
                        zf.write(full_path, arcname)
                        self.progress_update.emit(i + 1, len(all_files))

                self.status_update.emit("Finalizing file...")
                os.replace(temp_cbz, new_cbz_path) 
                
                if os.path.exists(self.file_path):
                    try: os.remove(self.file_path)
                    except: pass

                self.finished_conversion.emit(True, "Successfully converted CBR and tagged!", new_cbz_path)

        except Exception as e:
            self.finished_conversion.emit(False, f"Error: {e}", "")

