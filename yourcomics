class BatchTaggerThread(QThread):
    progress_update = pyqtSignal(int, str)
    finished = pyqtSignal()
    needs_confirmation = pyqtSignal(str, object, bytes)

    def __init__(self, file_paths, interactive=True):
        super().__init__()
        self.file_paths = file_paths
        self.interactive = interactive
        self.user_choice = None
        self.wait_event = threading.Event()

    def run(self):
        global COMIC_VINE_KEY
        headers = {"User-Agent": "YourComicsApp/1.0"}
        
        import patoolib

        for i, path in enumerate(self.file_paths):
            filename = os.path.basename(path)
            is_cbr = path.lower().endswith('.cbr')
            
            # 1. Skip if it already has metadata
            if not is_cbr:
                try:
                    with zipfile.ZipFile(path, 'r') as zf:
                        if 'ComicInfo.xml' in zf.namelist():
                            self.progress_update.emit(i, f"⏭️ Skipped {filename} (Already contains metadata)")
                            continue
                except Exception: 
                    pass
            
            # --- THE BULLETPROOF PARSER ---
            base_name = os.path.splitext(filename)[0]
            
            year_match = re.search(r'\((\d{4})\)', base_name)
            year_str = year_match.group(1) if year_match else ""
            
            clean_name = re.sub(r'\(.*?\)|\[.*?\]', '', base_name).strip()
            
            match = re.search(r'^(.*?)\s*#\s*(\d+)', clean_name)
            if not match: match = re.search(r'^(.*?)\s+(\d+)\s*$', clean_name)
                
            if match and match.group(1).strip():
                series = match.group(1).strip()
                issue = str(int(match.group(2)))  
            else:
                series = clean_name
                issue = ""
            
            search_text = f"{series} {issue} {year_str}".strip()
            self.progress_update.emit(i, f"🔍 Searching Vine: {search_text}...")

            # --- THE HYBRID TWO-STEP METHOD ---
            try:
                target_vol_id = None
                
                # STEP 1: FUZZY VOLUME SEARCH
                vol_query = urllib.parse.quote(series)
                vol_url = f"https://comicvine.gamespot.com/api/search/?api_key={COMIC_VINE_KEY}&format=json&resources=volume&query={vol_query}&limit=20"
                
                time.sleep(1.5)
                vol_response = requests.get(vol_url, headers=headers, timeout=10)
                vol_data = vol_response.json()
                
                if vol_data.get('error') == 'OK' and vol_data.get('number_of_total_results', 0) > 0:
                    for vol in vol_data['results']:
                        if year_str and str(vol.get('start_year')) == year_str:
                            target_vol_id = vol['id']
                            break
                    if not target_vol_id and vol_data['results']:
                        target_vol_id = vol_data['results'][0]['id']

                data = {'error': 'Failed', 'results': [], 'number_of_total_results': 0}

                # STEP 2: EXACT ISSUE MATCH
                if target_vol_id:
                    self.progress_update.emit(i, f"🎯 Step 2: Volume matched! Fetching Issue #{issue}...")
                    
                    issue_filter = f"volume:{target_vol_id}"
                    if issue:
                        issue_filter += f",issue_number:{issue}"
                        
                    issue_url = f"https://comicvine.gamespot.com/api/issues/?api_key={COMIC_VINE_KEY}&format=json&filter={urllib.parse.quote(issue_filter)}"
                    
                    time.sleep(1.5)
                    issue_response = requests.get(issue_url, headers=headers, timeout=10)
                    issue_data = issue_response.json()
                    
                    if issue_data.get('error') == 'OK' and issue_data.get('number_of_total_results', 0) > 0:
                        data = issue_data
                
                # STEP 3: THE OPTIONS GENERATOR
                if self.interactive or data.get('number_of_total_results', 0) == 0:
                    if data.get('number_of_total_results', 0) == 0:
                        self.progress_update.emit(i, f"⚠️ Strict match missed. Fetching fuzzy options...")
                    else:
                        self.progress_update.emit(i, f"➕ Fetching additional fuzzy options just in case...")
                        
                    query = urllib.parse.quote(search_text)
                    search_url = f"https://comicvine.gamespot.com/api/search/?api_key={COMIC_VINE_KEY}&format=json&resources=issue&query={query}&limit=10"
                    
                    time.sleep(1.5)
                    response = requests.get(search_url, headers=headers, timeout=10)
                    fuzzy_data = response.json()

                    if fuzzy_data.get('error') == 'OK':
                        existing_ids = {r['id'] for r in data.get('results', [])}
                        for r in fuzzy_data.get('results', []):
                            if r['id'] not in existing_ids:
                                data['results'].append(r)
                        data['number_of_total_results'] = len(data['results'])

                # --- PROCESS RESULTS & UI ---
                if data.get('number_of_total_results', 0) > 0:
                    
                    # INTERACTIVE MODE: Show UI to user
                    if self.interactive:
                        local_cover_bytes = b""
                        
                        if is_cbr:
                            temp_dir = tempfile.mkdtemp()
                            try:
                                patoolib.extract_archive(path, outdir=temp_dir, interactive=False)
                                images = sorted([os.path.join(r, f) for r, d, files in os.walk(temp_dir) for f in files if f.lower().endswith(('.jpg', '.jpeg', '.png'))])
                                if images:
                                    with open(images[0], 'rb') as f:
                                        local_cover_bytes = f.read()
                            except Exception: 
                                pass
                            finally:
                                if os.path.exists(temp_dir):
                                    shutil.rmtree(temp_dir, onerror=force_remove_readonly)
                        else:
                            try:
                                with zipfile.ZipFile(path, 'r') as zf:
                                    images = sorted([f for f in zf.namelist() if f.lower().endswith(('.jpg', '.jpeg', '.png'))])
                                    if images:
                                        local_cover_bytes = zf.read(images[0])
                            except Exception: 
                                pass

                        self.user_choice = None
                        self.wait_event.clear() 
                        
                        self.needs_confirmation.emit(filename, data['results'], local_cover_bytes)
                        self.wait_event.wait()
                        
                        if not self.user_choice:
                            self.progress_update.emit(i, f"⏭️ Skipped by user: {filename}")
                            continue
                        issue_data = self.user_choice
                    else:
                        issue_data = data['results'][0]

                    # BUILD XML
                    comic_info = ET.Element("ComicInfo", {"xmlns:xsi": "http://www.w3.org/2001/XMLSchema-instance", "xmlns:xsd": "http://www.w3.org/2001/XMLSchema"})
                    ET.SubElement(comic_info, "Series").text = series
                    if issue:
                        ET.SubElement(comic_info, "Number").text = issue
                    if issue_data.get('volume'): 
                        ET.SubElement(comic_info, "Volume").text = issue_data['volume'].get('name', '')
                    if issue_data.get('name'): 
                        ET.SubElement(comic_info, "Title").text = issue_data['name']
                    if issue_data.get('cover_date'): 
                        ET.SubElement(comic_info, "Year").text = issue_data['cover_date'].split('-')[0]
                    
                    # --- FIX 1: Grab massive description first, clean out any HTML, then fall back to deck ---
                    desc = issue_data.get('description') or issue_data.get('deck') or ""
                    desc = re.sub(r'<[^>]+>', '', desc).strip()
                    if desc: 
                        ET.SubElement(comic_info, "Summary").text = desc

                    # --- FIX 2: Extract Writers and Artists from the credits list ---
                    writers, artists = [], []
                    for person in issue_data.get("person_credits", []):
                        roles = person.get("role", "").lower()
                        name = person.get("name", "")
                        if "writer" in roles: writers.append(name)
                        if "penciler" in roles or "artist" in roles: artists.append(name)
                            
                    if writers: ET.SubElement(comic_info, "Writer").text = ", ".join(writers)
                    if artists: ET.SubElement(comic_info, "Penciller").text = ", ".join(artists)
                    
                    # --- NEW: Extract Story Arcs and Alternate Event info! ---
                    story_arcs = []
                    if issue_data.get("story_arc"): story_arcs.append(str(issue_data.get("story_arc")))
                    for arc in issue_data.get("story_arc_credits", []):
                        story_arcs.append(arc.get("name", ""))
                    
                    unique_arcs = []
                    for a in story_arcs:
                        if a and a not in unique_arcs: unique_arcs.append(a)
                    if unique_arcs: ET.SubElement(comic_info, "StoryArc").text = ", ".join(unique_arcs)
                    
                    alt_series = str(issue_data.get("alternate_series") or "").strip()
                    if alt_series: ET.SubElement(comic_info, "AlternateSeries").text = alt_series
                    
                    alt_num = str(issue_data.get("alternate_number") or "").strip()
                    if alt_num: ET.SubElement(comic_info, "AlternateNumber").text = alt_num
                    
                    alt_count = str(issue_data.get("alternate_count") or "").strip()
                    if alt_count: ET.SubElement(comic_info, "AlternateCount").text = alt_count
                    
                    ET.SubElement(comic_info, "PlayCount").text = "1"
                    # ---------------------------------------------------------
                    
                    # Convert it all into a string to inject!
                    xml_str = '<?xml version="1.0" encoding="utf-8"?>\n' + ET.tostring(comic_info, encoding='unicode')

                    # INJECT METADATA / CBR TO CBZ CONVERSION
                    if is_cbr:
                        self.progress_update.emit(i, f"📦 Extracting {filename} (This may take a moment)...")
                        temp_dir = tempfile.mkdtemp()
                        try:
                            patoolib.extract_archive(path, outdir=temp_dir, interactive=False)
                            
                            files_to_zip = []
                            for root, _, files in os.walk(temp_dir):
                                for f in files:
                                    files_to_zip.append(os.path.join(root, f))
                                    
                            total_files = len(files_to_zip)
                            new_cbz_path = os.path.splitext(path)[0] + '.cbz'
                            self.progress_update.emit(i, f"📦 Repacking {total_files} pages into .cbz...")
                            
                            last_milestone = 0
                            with zipfile.ZipFile(new_cbz_path, 'w', zipfile.ZIP_DEFLATED) as zf:
                                for idx, file_path in enumerate(files_to_zip):
                                    arcname = os.path.relpath(file_path, temp_dir)
                                    zf.write(file_path, arcname)
                                    
                                    percent = int(((idx + 1) / total_files) * 100)
                                    if percent >= last_milestone + 25:
                                        self.progress_update.emit(i, f"   ↳ Repacking progress: {percent}%")
                                        last_milestone = percent
                                        
                                zf.writestr('ComicInfo.xml', xml_str)
                                
                            shutil.rmtree(temp_dir, onerror=force_remove_readonly)
                            os.remove(path)
                            self.progress_update.emit(i, f"✅ Converted & Tagged: {os.path.basename(new_cbz_path)}")
                        except Exception as e:
                            self.progress_update.emit(i, f"⚠️ Conversion failed: {str(e)}")
                            if os.path.exists(temp_dir): 
                                shutil.rmtree(temp_dir, onerror=force_remove_readonly)
                    else:
                        with zipfile.ZipFile(path, 'a') as zf:
                            zf.writestr('ComicInfo.xml', xml_str)
                            self.progress_update.emit(i, f"✅ Tagged: {filename}")
                else:
                    self.progress_update.emit(i, f"❌ No match on Vine for: {filename}")

            except Exception as e:
                self.progress_update.emit(i, f"⚠️ Error tagging {filename}: {str(e)}")
                self.wait_event.set()

        self.progress_update.emit(len(self.file_paths), "🎉 Batch Tagging Complete!")
        self.finished.emit()

