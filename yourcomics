class ComicVineIssueThread(QThread):
    # This signal sends the dictionary of metadata back to the UI
    issue_ready = pyqtSignal(dict)

    def __init__(self, vol_id=None, issue_num=None, direct_api_url=None):
        super().__init__()
        self.vol_id = vol_id
        self.issue_num = issue_num
        self.direct_api_url = direct_api_url

    def run(self):
        global COMIC_VINE_KEY
        headers = {"User-Agent": "YourComicsApp/1.0"}

        try:
            time.sleep(1.5)  # Respect API limits

            # SCENARIO 1: The Convert Button gave us a direct URL
            if self.direct_api_url:
                url = f"{self.direct_api_url}?api_key={COMIC_VINE_KEY}&format=json"
            
            # SCENARIO 2: The Finder Tab gave us a Volume ID and Issue Number
            else:
                issue_filter = f"volume:{self.vol_id}"
                if self.issue_num:
                    issue_filter += f",issue_number:{self.issue_num}"
                url = f"https://comicvine.gamespot.com/api/issues/?api_key={COMIC_VINE_KEY}&format=json&filter={urllib.parse.quote(issue_filter)}"

            response = requests.get(url, headers=headers, timeout=10)
            data = response.json()

            if data.get('error') == 'OK':
                if self.direct_api_url:
                    # The direct URL endpoint returns a single dictionary object
                    self.issue_ready.emit(data.get('results', {}))
                else:
                    # The filter endpoint returns a list of results
                    results = data.get('results', [])
                    self.issue_ready.emit(results[0] if results else {})
            else:
                self.issue_ready.emit({})

        except Exception as e:
            print(f"Error fetching full issue data: {e}")
            self.issue_ready.emit({})

