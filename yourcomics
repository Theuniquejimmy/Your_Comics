class DeepSearchThread(QThread):
    results_ready = pyqtSignal(list)
    
    def __init__(self, query, libraries):
        super().__init__()
        self.query = query.lower()
        self.libraries = libraries
        
    def run(self):
        results = []
        for lib in self.libraries:
            if not os.path.exists(lib): continue
            for root, dirs, files in os.walk(lib):
                for d in dirs:
                    if self.query in d.lower():
                        results.append({"name": d, "path": os.path.join(root, d), "is_folder": True})
                for f in files:
                    if f.lower().endswith(('.cbz', '.cbr', '.cbl')) and self.query in f.lower():
                        results.append({"name": f, "path": os.path.join(root, f), "is_folder": False})
        self.results_ready.emit(results)

class DraggableSearchList(QListWidget):
    def __init__(self):
        super().__init__()
        self.setDragEnabled(True)
        self.setSelectionMode(QAbstractItemView.SelectionMode.ExtendedSelection)
        self.setStyleSheet("background-color: #21222c; border: 1px solid #44475a; color: white; padding: 5px;")
        
    def mimeData(self, items):
        mime = QMimeData()
        urls = []
        for item in items:
            path = item.data(Qt.ItemDataRole.UserRole)
            if path:
                urls.append(QUrl.fromLocalFile(path))
        mime.setUrls(urls)
        return mime
