    def fetch_ai_info(self):
        if not self.current_comic_path: 
            return
            
        # 1. Clean up the filename so the AI knows exactly what comic we are talking about
        import re
        base_name = os.path.splitext(os.path.basename(self.current_comic_path))[0]
        clean_title = re.sub(r'\(.*?\)|\[.*?\]', '', base_name).strip()

        # 2. Find which tab is the Comic Chat and switch to it instantly
        chat_index = self.tabs.indexOf(self.chat_tab)
        if chat_index != -1:
            self.tabs.setCurrentIndex(chat_index)

        # 3. Formulate the question, inject it into the chat box, and hit send!
        if hasattr(self.chat_tab, 'chat_input'):
            # Craft a clear prompt for the Interrogator
            question = f"Can you give me a summary, background info, and details about the comic: {clean_title}?"
            self.chat_tab.chat_input.setText(question)
            
            # Click the send button to automatically ask the AI!
            if hasattr(self.chat_tab, 'send_btn'):
                self.chat_tab.send_btn.click()
            elif hasattr(self.chat_tab, 'send_message'):
                self.chat_tab.send_message()

    def load_prev_comic(self):
        # Find exactly where we are in the left-panel tree
        current_index = self.tree.currentIndex()
        if current_index.isValid():
            # Grab the item directly above it and select it
            prev_idx = self.tree.indexAbove(current_index)
            if prev_idx.isValid():
