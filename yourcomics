class ComicVineIssueSearchThread(QThread):
    results_ready = pyqtSignal(list)

    def __init__(self, query):
        super().__init__()
        self.query = query.strip()

    def run(self):
        global COMIC_VINE_KEY
        headers = {"User-Agent": "YourComicsApp/1.0"}
        
        import urllib.parse
        import requests
        import time
        import re

        # --- THE QUERY PARSER ---
        year_match = re.search(r'\b(19\d{2}|20\d{2})\b', self.query)
        year_str = year_match.group(1) if year_match else None

        temp_query = re.sub(r'\b(19\d{2}|20\d{2})\b', '', self.query).strip()

        issue_match = re.search(r'(?:#\s*)?(\d+)(?!\d)$', temp_query)
        if issue_match:
            issue = str(int(issue_match.group(1)))
            series = temp_query[:issue_match.start()].strip()
        else:
            issue = ""
            series = temp_query

        if not series:
            series = self.query
            issue = ""
            year_str = None

        # 🚨 THIS IS THE FIX: Declared at the absolute root level! 🚨
        final_results = []

        # --- THE HYBRID TWO-STEP METHOD ---
        try:
            target_vol_id = None
            
            # STEP 1: FUZZY VOLUME SEARCH
            vol_query = urllib.parse.quote(series)
            vol_url = f"https://comicvine.gamespot.com/api/search/?api_key={COMIC_VINE_KEY}&format=json&resources=volume&query={vol_query}&limit=20"
            
            time.sleep(1.5)
            vol_response = requests.get(vol_url, headers=headers, timeout=10)
            vol_data = vol_response.json()
            
            if vol_data.get('error') == 'OK' and vol_data.get('number_of_total_results', 0) > 0:
                for vol in vol_data['results']:
                    if year_str and str(vol.get('start_year')) == year_str:
                        target_vol_id = vol['id']
                        break
                if not target_vol_id and vol_data['results']:
                    target_vol_id = vol_data['results'][0]['id']

            # STEP 2: EXACT ISSUE MATCH
            if target_vol_id:
                issue_filter = f"volume:{target_vol_id}"
                if issue:
                    issue_filter += f",issue_number:{issue}"
                    
                issue_url = f"https://comicvine.gamespot.com/api/issues/?api_key={COMIC_VINE_KEY}&format=json&filter={urllib.parse.quote(issue_filter)}"
                
                time.sleep(1.5)
                issue_response = requests.get(issue_url, headers=headers, timeout=10)
                issue_data = issue_response.json()
                
                if issue_data.get('error') == 'OK' and issue_data.get('number_of_total_results', 0) > 0:
                    final_results = issue_data['results']
            
            # STEP 3: THE OPTIONS GENERATOR (Fuzzy Fallback/Addition)
            search_url = f"https://comicvine.gamespot.com/api/search/?api_key={COMIC_VINE_KEY}&format=json&resources=issue&query={urllib.parse.quote(self.query)}&limit=10"
            time.sleep(1.5)
            response = requests.get(search_url, headers=headers, timeout=10)
            fuzzy_data = response.json()
            
            if fuzzy_data.get('error') == 'OK':
                existing_ids = {r['id'] for r in final_results}
                for r in fuzzy_data.get('results', []):
                    if r['id'] not in existing_ids:
                        final_results.append(r)

        except Exception as e:
            print(f"Manual Search Error: {e}")
            
        # Send the final list of issues directly to your UI!
        self.results_ready.emit(final_results)

