    def build_xml(self):
        data = self.selected_issue_data
        title = str(data.get("name") or "").replace("&", "&amp;").replace("<", "&lt;")
        series = str(data.get("volume", {}).get("name") or "").replace("&", "&amp;").replace("<", "&lt;")
        number = str(data.get("issue_number") or "")
        
        # Grab description first, clean out HTML, then fallback to deck
        import re
        desc = data.get("description") or data.get("deck") or ""
        desc = re.sub(r'<[^>]+>', '', desc).strip().replace("&", "&amp;").replace("<", "&lt;")
        
        year, month = "", ""
        date_str = data.get("cover_date") or ""
        if date_str:
            parts = date_str.split('-')
            if len(parts) >= 1: year = parts[0]
            if len(parts) >= 2: month = parts[1]
            
        writers, artists = [], []
        for person in data.get("person_credits", []):
            roles = person.get("role", "").lower()
            name = person.get("name", "").replace("&", "&amp;").replace("<", "&lt;")
            if "writer" in roles: writers.append(name)
            if "penciler" in roles or "artist" in roles or "penciller" in roles: artists.append(name)
            
        writer_str = ", ".join(writers)
        artist_str = ", ".join(artists)

        # --- THE NEW TAGS: Arc & Alternate Info ---
        story_arcs = []
        if data.get("story_arc"): story_arcs.append(str(data.get("story_arc")))
        for arc in data.get("story_arc_credits", []):
            story_arcs.append(arc.get("name", ""))
            
        unique_arcs = []
        for a in story_arcs:
            clean_arc = a.replace("&", "&amp;").replace("<", "&lt;")
            if clean_arc and clean_arc not in unique_arcs: unique_arcs.append(clean_arc)
        arc_str = ", ".join(unique_arcs)
        
        alt_series = str(data.get("alternate_series") or "").replace("&", "&amp;").replace("<", "&lt;")
        alt_num = str(data.get("alternate_number") or "")
        alt_count = str(data.get("alternate_count") or "")

        xml = [
            '<?xml version="1.0" encoding="utf-8"?>',
            '<ComicInfo xmlns:xsd="http://www.w3.org/2001/XMLSchema" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance">',
            f'  <Title>{title}</Title>' if title else '',
            f'  <Series>{series}</Series>' if series else '',
            f'  <Number>{number}</Number>' if number else '',
            f'  <Summary>{desc}</Summary>' if desc else '',
            f'  <Year>{year}</Year>' if year else '',
            f'  <Month>{month}</Month>' if month else '',
            f'  <Writer>{writer_str}</Writer>' if writer_str else '',
            f'  <Penciller>{artist_str}</Penciller>' if artist_str else '',
            f'  <StoryArc>{arc_str}</StoryArc>' if arc_str else '',
            f'  <AlternateSeries>{alt_series}</AlternateSeries>' if alt_series else '',
            f'  <AlternateNumber>{alt_num}</AlternateNumber>' if alt_num else '',
            f'  <AlternateCount>{alt_count}</AlternateCount>' if alt_count else '',
            '  <PlayCount>1</PlayCount>',
            '</ComicInfo>'
        ]
        return "\n".join(filter(None, xml))               


