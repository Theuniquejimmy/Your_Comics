class GithubCBLFetchThread(QThread):
    """Fetches directory contents from the DieselTech CBL repo via GitHub API."""
    results_ready = pyqtSignal(list)   # list of dicts: {name, path, type, download_url}
    error_signal  = pyqtSignal(str)

    BASE = "https://api.github.com/repos/DieselTech/CBL-ReadingLists/contents/"

    def __init__(self, path=""):
        super().__init__()
        self.path = path

    def run(self):
        try:
            url  = self.BASE + urllib.parse.quote(self.path, safe="/")
            resp = requests.get(url, headers={"User-Agent": "ComicVault/1.0"}, timeout=10)
            resp.raise_for_status()
            items = resp.json()
            results = []
            for item in items:
                if item.get("type") in ("dir", "file"):
                    name = item["name"]
                    if item["type"] == "file" and not name.lower().endswith(".cbl"):
                        continue          # skip non-CBL files
                    if name.startswith("."):
                        continue          # skip hidden files
                    results.append({
                        "name":         name,
                        "path":         item["path"],
                        "type":         item["type"],
                        "download_url": item.get("download_url") or "",
                    })
            # Folders first, then files, both alphabetical
            results.sort(key=lambda x: (x["type"] == "file", x["name"].lower()))
            self.results_ready.emit(results)
        except Exception as e:
            self.error_signal.emit(str(e))


class GithubCBLDownloadThread(QThread):
    """Downloads a single CBL file from GitHub and saves it to disk."""
    finished = pyqtSignal(str)   # path saved to
    error    = pyqtSignal(str)

    def __init__(self, download_url: str, save_path: str):
        super().__init__()
        self.download_url = download_url
        self.save_path    = save_path

    def run(self):
        try:
            resp = requests.get(
                self.download_url,
                headers={"User-Agent": "ComicVault/1.0"},
                timeout=15,
            )
            resp.raise_for_status()
            with open(self.save_path, "wb") as f:
                f.write(resp.content)
            self.finished.emit(self.save_path)
        except Exception as e:
            self.error.emit(str(e))

