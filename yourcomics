# --- NATURAL SORTING MIDDLEMAN ---
class NaturalSortProxyModel(QSortFilterProxyModel):
    def lessThan(self, source_left, source_right):
        left_data = self.sourceModel().data(source_left)
        right_data = self.sourceModel().data(source_right)
        
        left_str = str(left_data) if left_data else ""
        right_str = str(right_data) if right_data else ""

        # Break the string into chunks of letters and whole numbers
        def natural_sort_key(s):
            import re
            return [int(text) if text.isdigit() else text.lower() for text in re.split(r'(\d+)', s)]

        return natural_sort_key(left_str) < natural_sort_key(right_str)

from PyQt6.QtGui import QImage

class CoverLoaderThread(QThread):
    # Notice we changed bytes to QImage!
    cover_loaded = pyqtSignal(str, QImage)

    def __init__(self, file_paths):
        super().__init__()
        self.file_paths = file_paths
        self._is_running = True

    def run(self):
        for file_path in self.file_paths:
            if not self._is_running: break 
            try:
                norm_path = os.path.normpath(file_path)
                img_data = None
                file_hash = hashlib.md5(norm_path.encode('utf-8')).hexdigest()
                cache_path = os.path.join(CACHE_DIR, f"{file_hash}.jpg")

                if os.path.exists(cache_path):
                    with open(cache_path, 'rb') as f:
                        img_data = f.read()

                if not img_data:
                    if file_path.lower().endswith('.cbz'):
                        with zipfile.ZipFile(file_path, 'r') as zf:
                            image_files = [f for f in zf.namelist() if f.lower().endswith(('.jpg', '.jpeg', '.png'))]
                            image_files = [f for f in image_files if not f.endswith('/')]
                            image_files.sort()
                            if image_files: img_data = zf.read(image_files[0])
                    elif file_path.lower().endswith('.cbr') and HAS_RAR:
                        with rarfile.RarFile(file_path, 'r') as rf:
                            image_files = [f for f in rf.namelist() if f.lower().endswith(('.jpg', '.jpeg', '.png'))]
                            image_files = [f for f in image_files if not f.endswith('/') and not f.endswith('\\')]
                            image_files.sort()
                            if image_files: img_data = rf.read(image_files[0])
                    
                    if img_data:
                        try:
                            with open(cache_path, 'wb') as f: f.write(img_data)
                        except Exception: pass 

                if img_data:
                    # Do the heavy resizing work IN THE BACKGROUND so the UI never freezes!
                    image = QImage()
                    image.loadFromData(img_data)
                    scaled_image = image.scaled(180, 270, Qt.AspectRatioMode.KeepAspectRatio, Qt.TransformationMode.SmoothTransformation)
                    self.cover_loaded.emit(norm_path, scaled_image)
            except Exception: pass 

    def stop(self):
        self._is_running = False

class ComicVineSearchThread(QThread):
    results_ready = pyqtSignal(list)
    def __init__(self, query):
        super().__init__()
        self.query = query

    def run(self):
        url = "https://comicvine.gamespot.com/api/search/"
        params = {"api_key": COMIC_VINE_KEY, "format": "json", "query": self.query, "resources": "volume", "limit": 50}
        try:
            res = requests.get(url, params=params, headers={"User-Agent": "ComicVault/1.0"}).json()
            results = res.get('results', [])
            results.sort(key=lambda x: int(re.search(r'\d+', str(x.get('start_year', 9999))).group()) if re.search(r'\d+', str(x.get('start_year', 9999))) else 9999)
            self.results_ready.emit(results)
        except:
            self.results_ready.emit([])

