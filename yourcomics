def _the_variants(series: str) -> list:
    """Return search queries to try for series names that may have a leading 'The'.
    'Sensational She-Hulk' → ['Sensational She-Hulk', 'The Sensational She-Hulk']
    'The Batman'           → ['The Batman', 'Batman']
    """
    s = series.strip()
    if re.match(r'(?i)^the\s+', s):
        return [s, re.sub(r'(?i)^the\s+', '', s).strip()]
    else:
        return [s, f"The {s}"]


def _norm_vol_name(s: str) -> str:
    """Normalise a volume name for fuzzy matching.
    Converts colons, dashes, underscores to spaces and collapses whitespace
    so "Dark Days: The Forge" == "Dark Days - The Forge" == "Dark Days The Forge".
    """
    s = re.sub(r'[:–—_-]', ' ', s.lower())
    s = re.sub(r'^the\s+', '', s)  # strip leading 'the' for comparison
    return re.sub(r'\s+', ' ', s).strip()


def _score_volume(vol: dict, series_name: str, issue_num: str, year_str: str,
                  subtitle: str = "", vol_num: str = "") -> int:
    """Score a Comic Vine volume result so the best match sorts first."""
    score = 0
    vol_name_raw  = str(vol.get('name') or '').lower().strip()
    want_name_raw = series_name.lower().strip()
    want_sub_raw  = subtitle.lower().strip()

    # Normalised forms (colon/dash → space) for fuzzy matching
    vol_name_n  = _norm_vol_name(vol_name_raw)
    want_name_n = _norm_vol_name(want_name_raw)
    want_sub_n  = _norm_vol_name(want_sub_raw)

    # Subtitle match (TPB named volumes e.g. "Batman: Superheavy")
    if want_sub_n and f"{want_name_n} {want_sub_n}" in vol_name_n:
        score += 60
    elif want_sub_n and want_sub_n in vol_name_n:
        score += 20

    # Series name match — prefer normalised exact, then raw exact, then contains
    if vol_name_n == want_name_n:
        score += 50
    elif vol_name_raw == want_name_raw:
        score += 50
    elif want_name_n and want_name_n in vol_name_n:
        score += 25
    elif want_name_raw and want_name_raw in vol_name_raw:
        score += 20
    elif want_name_n and vol_name_n in want_name_n:
        # series name contains the vol name (e.g. "Dark Days" in "Dark Days - The Forge")
        score += 10

    count = int(vol.get('count_of_issues') or 0)
    if issue_num:
        try:
            if count >= int(issue_num):
                score += 30
        except ValueError:
            pass
    elif vol_num:
        try:
            if count >= int(vol_num):
                score += 15
        except ValueError:
            pass

    # Proximity year scoring
    if year_str:
        try:
            iy = int(year_str)
            sy = int(vol.get('start_year') or 0)
            if sy > 0 and sy <= iy:
                gap = iy - sy
                if gap <= 2:
                    score += 30
                elif gap <= 5:
                    score += 22
                elif gap <= 10:
                    score += 15
                elif gap <= 20:
                    score += 8
        except (ValueError, TypeError):
            pass

    # Boost "deluxe edition" / "book" style collected volumes when we have a
    # vol_num — these are almost always what "Book NN" filenames refer to.
    # Without this the main series (exact name match +50) beats the Deluxe Edition.
    if vol_num:
        vol_name_n_check = _norm_vol_name(vol_name_raw)
        if 'deluxe' in vol_name_n_check or 'omnibus' in vol_name_n_check:
            score += 35
        elif re.search(r'\bbook\b', vol_name_n_check):
            score += 20

    score += min(10, count // 20)

    # Prefer known English-language publishers so the vol picker never latches
    # onto a Spanish/French/German edition of the same series
    publisher = str((vol.get('publisher') or {}).get('name') or '').lower()
    english_publishers = {'dc comics', 'marvel comics', 'image comics',
                          'dark horse comics', 'idw publishing', 'boom! studios',
                          'dynamite entertainment', 'valiant', 'vertigo', 'wildstorm',
                          'aftershock comics', 'oni press'}
    if any(ep in publisher for ep in english_publishers):
        score += 25
    elif publisher and any(c in publisher for c in ('edicion', 'panini', 'planeta',
                                                     'glenat', 'urban', 'semic',
                                                     'ehapa', 'dino', 'mg publishing')):
        score -= 40

    return score


def parse_comic_filename_full(base_name: str) -> dict:
    """Parse any comic filename into structured fields.

    Handles: reading-order prefixes, #NN, bare NN, vNN/Vol NN/Book NN,
    TPB/omnibus keywords, One-Shot, story-annotation noise, dash subtitles,
    and embedded cover-date strings.

    Returns dict: series, vol_num, issue, subtitle, year, is_tpb
    """
    year_match = re.search(r'\((\d{4})\)', base_name)
    year = year_match.group(1) if year_match else ""

    # Also pick up year from bare date strings like "1994-04-00" not inside parens
    if not year:
        m_bare_year = re.search(r'\b(19|20)(\d{2})-\d{2}', base_name)
        if m_bare_year:
            year = m_bare_year.group(1) + m_bare_year.group(2)

    # Extract edition keywords from brackets BEFORE stripping them.
    edition_hint = ""
    # Also extract issue numbers encoded inside brackets as (_NN) or (#NN) or (NN)
    # e.g. "(_21)" from Glorith-HD releases like "Darkstars, 1994-04-00 (_21)"
    bracket_issue = ""
    for bracket in re.findall(r'\(([^)]+)\)', base_name):
        bl = bracket.lower().strip()
        if 'omnibus' in bl:
            edition_hint = 'omnibus'
        elif 'deluxe' in bl:
            edition_hint = 'deluxe'
        # Issue inside bracket: _NN, #NN, or bare integer (skip year-like 4-digit numbers)
        if not bracket_issue:
            m_bi = re.match(r'^[_#]?\s*(\d{1,4})\s*$', bl)
            if m_bi and len(m_bi.group(1)) <= 3:
                bracket_issue = str(int(m_bi.group(1)))

    clean = re.sub(r'\(.*?\)|\[.*?\]', '', base_name).strip()
    clean = re.sub(r'[\s\-_]+$', '', clean).strip()

    # Normalise underscores → spaces (common in Empire/Glorith release filenames)
    # Do this BEFORE trailing-junk strip so "..._002_" is handled correctly
    clean = re.sub(r'_', ' ', clean)
    clean = re.sub(r' {2,}', ' ', clean).strip()
    clean = re.sub(r'[\s\-]+$', '', clean).strip()

    # Strip leading reading-order prefixes: "008 ", "002 - ", "15. "
    # Only strip if the number is zero-padded (starts with 0: 001, 008)
    # OR is 1-2 bare digits (1, 5, 12). Never strip 100+, which are title words.
    clean = re.sub(r'^(0\d*|\d{1,2})[\.\-\s]+', '', clean).strip()

    # Strip embedded cover-date strings: ", 1996-12-00" or "1996-01"
    clean = re.sub(r',?\s*(19|20)\d{2}-\d{2}(-\d{2})?', '', clean).strip()
    clean = re.sub(r'[,\s]+$', '', clean).strip()

    # Strip story-annotation noise: "B story", "A story", "c stories" etc.
    clean = re.sub(r'\s+[A-Ca-c]\s+stor(?:y|ies)\b.*$', '', clean, flags=re.I).strip()

    # Strip bare trailing year not inside parens: "...1998"
    clean = re.sub(r'\s+(19|20)\d{2}\s*$', '', clean).strip()

    # Case 1: issue with #
    m_issue = re.search(r'^(.*?)\s*#\s*(\d+)', clean)
    if m_issue:
        series = re.sub(r'\s+(?:v|vol|volume)\.?\s*\d+$', '',
                        m_issue.group(1).strip(), flags=re.I).strip()
        return dict(series=series, vol_num="", issue=str(int(m_issue.group(2))),
                    subtitle="", year=year, is_tpb=False)

    # Case 2: vNN / Vol NN / Book NN (before dash check)
    m_vol = re.search(r'(?i)(?<!\w)(?:v|vol|volume|book|bk)\.?\s*0*(\d+)\b', clean)
    if m_vol:
        series = clean[:m_vol.start()].strip().rstrip('-\u2013\u2014 \t')
        vol_num = m_vol.group(1)
        after = clean[m_vol.end():].strip()
        m_sub = re.match(r'^[-\u2013\u2014:]\s*(.+)', after)
        subtitle = m_sub.group(1).strip() if m_sub else ""
        # If no subtitle: check edition_hint from brackets first (e.g. Omnibus),
        # then synthesise "Book N" if the vol token was "Book NN"
        if not subtitle:
            if edition_hint:
                subtitle = edition_hint
            elif re.match(r'(?i)book', m_vol.group(0).strip()):
                subtitle = f"Book {vol_num}"
        return dict(series=series, vol_num=vol_num, issue="",
                    subtitle=subtitle, year=year, is_tpb=True)

    # Case 3: TPB / omnibus keyword
    m_tpb = re.search(
        r'(?i)\b(tpb|trade\s+paperback|graphic\s+novel|omnibus|compendium|deluxe)\b', clean)
    if m_tpb:
        series = clean[:m_tpb.start()].strip().rstrip('-\u2013\u2014 ')
        subtitle = clean[m_tpb.end():].strip().lstrip('-\u2013\u2014 ')
        return dict(series=series, vol_num="", issue="",
                    subtitle=subtitle, year=year, is_tpb=True)

    # Case 4: One-Shot keyword — strip it and the trailing number is issue 1
    m_oneshot = re.search(r'(?i)\bone-?shot\b', clean)
    if m_oneshot:
        without = (clean[:m_oneshot.start()] + clean[m_oneshot.end():]).strip().rstrip('-\u2013\u2014 ')
        m_trail = re.search(r'^(.*?)\s+0*(\d+)\s*$', without)
        if m_trail and m_trail.group(1).strip():
            series = m_trail.group(1).strip()
        else:
            series = without
        return dict(series=series, vol_num="", issue="1", subtitle="", year=year, is_tpb=False)

    # Case 5: dash separator
    m_dash = re.search(r'\s+[-\u2013\u2014]\s+', clean)
    if m_dash:
        left  = clean[:m_dash.start()].strip()
        right = clean[m_dash.end():].strip()

        # 5a: left ends with a number → "Tales from AoA 02 - Sinister Bloodlines"
        m_left_num = re.search(r'^(.*?)\s+0*(\d+)\s*$', left)
        if m_left_num and m_left_num.group(1).strip():
            subtitle = re.sub(r'\s+(19|20)\d{2}\s*$', '', right).strip()
            return dict(series=m_left_num.group(1).strip(), vol_num="",
                        issue=str(int(m_left_num.group(2))), subtitle=subtitle,
                        year=year, is_tpb=False)

        if not re.match(r'^\d+\s*$', right):
            # 5b: right ends with a number → "Batman - Legends of the Dark Knight 002"
            m_right_num = re.search(r'^(.*?)\s+0*(\d+)\s*$', right)
            if m_right_num and m_right_num.group(1).strip():
                # Preserve dash so series matches CV: "Batman - Legends of the Dark Knight"
                full_series = f"{left} - {m_right_num.group(1).strip()}".strip()
                return dict(series=full_series, vol_num="",
                            issue=str(int(m_right_num.group(2))),
                            subtitle="", year=year, is_tpb=False)
            # 5c: pure subtitle ("Batman - The Dark Knight Returns")
            return dict(series=left, vol_num="", issue="",
                        subtitle=right, year=year, is_tpb=True)

    # Case 6: bare trailing number ("Batman 021", "X-Men Chronicles 002")
    m_end = re.search(r'^(.*?)\s+0*(\d+)\s*$', clean)
    if m_end and m_end.group(1).strip() and not re.match(r'^\d+$', m_end.group(1).strip()):
        return dict(series=m_end.group(1).strip(), vol_num="", issue=str(int(m_end.group(2))),
                    subtitle="", year=year, is_tpb=False)

    # bracket_issue fallback: covers "_21" style Glorith-HD releases where
    # the issue number is only inside a bracket e.g. "Darkstars, 1994 (_21)"
    if bracket_issue:
        return dict(series=clean, vol_num="", issue=bracket_issue,
                    subtitle="", year=year, is_tpb=False)

    return dict(series=clean, vol_num="", issue="", subtitle="", year=year, is_tpb=False)


class ComicVineSearchThread(QThread):
    results_ready = pyqtSignal(list)
    def __init__(self, query):
        super().__init__()
        self.query = query

    def run(self):
        headers = {"User-Agent": "ComicVault/1.0"}
        encoded = urllib.parse.quote(self.query)
        combined = {}   # vol_id -> result dict, deduped
        try:
            # ── Pass 1: broad filter (volumes endpoint) ──
            # Returns everything whose name *contains* the query words (~70 results)
            filter_url = (
                f"https://comicvine.gamespot.com/api/volumes/"
                f"?api_key={COMIC_VINE_KEY}&format=json"
                f"&filter=name:{encoded}&limit=50"
                f"&field_list=id,name,start_year,publisher,count_of_issues,image,api_detail_url"
            )
            r1 = requests.get(filter_url, headers=headers, timeout=10).json()
            if r1.get('error') == 'OK':
                for v in r1.get('results', []):
                    combined[v['id']] = v

            time.sleep(0.5)

            # ── Pass 2: exact search (search endpoint) ──
            # Returns only volumes whose name is very close to the query (~8 results)
            search_url = (
                f"https://comicvine.gamespot.com/api/search/"
                f"?api_key={COMIC_VINE_KEY}&format=json"
                f"&resources=volume&query={encoded}&limit=25"
            )
            r2 = requests.get(search_url, headers=headers, timeout=10).json()
            if r2.get('error') == 'OK':
                for v in r2.get('results', []):
                    combined[v['id']] = v

            # Pass 3: try 'The {query}' variants for finder volume dropdown
            for _the_variant in _the_variants(self.query)[1:]:
                if _the_variant.lower() != self.query.lower():
                    time.sleep(0.4)
                    _tq = urllib.parse.quote(_the_variant)
                    _tr = requests.get(
                        f"https://comicvine.gamespot.com/api/volumes/"
                        f"?api_key={COMIC_VINE_KEY}&format=json"
                        f"&filter=name:{_tq}&limit=20"
                        f"&field_list=id,name,start_year,publisher,count_of_issues,image,api_detail_url",
                        headers=headers, timeout=10
                    ).json()
                    if _tr.get('error') == 'OK':
                        for v in _tr.get('results', []):
                            combined[v['id']] = v

        except Exception as _e:
            log.warning("ComicVineSearchThread failed: %s", _e)

        results = list(combined.values())
        # Sort: most issues first (main run before limited series / tie-ins),
        # then by start_year ascending as a tiebreaker
        results.sort(key=lambda x: (
            -int(x.get('count_of_issues') or 0),
            int(re.search(r'\d+', str(x.get('start_year', 9999))).group())
            if re.search(r'\d+', str(x.get('start_year', 9999))) else 9999
        ))
        self.results_ready.emit(results)

class ComicVineIssueSearchThread(QThread):
    results_ready = pyqtSignal(list)

    def __init__(self, query):
        super().__init__()
        self.query = query.strip()

    def run(self):
        global COMIC_VINE_KEY
        headers = {"User-Agent": "YourComicsApp/1.0"}
        

        # --- THE QUERY PARSER ---
        parsed   = parse_comic_filename_full(self.query)
        series   = parsed['series']
        issue    = parsed['issue']
        year_str = parsed['year']
        subtitle = parsed['subtitle']
        vol_num  = parsed['vol_num']

        if not series:
            series   = self.query
            issue    = ""
            year_str = ""
            subtitle = ""
            vol_num  = ""

        # 🚨 THIS IS THE FIX: Declared at the absolute root level! 🚨
        final_results = []

        # --- THE HYBRID TWO-STEP METHOD ---
        try:
            target_vol_id = None

            # STEP 1: VOLUME SEARCH — broad filter + exact search, merged
            vol_query = urllib.parse.quote(series)
            vol_combined = {}

            # Pass 1a: broad filter endpoint
            filter_url = (
                f"https://comicvine.gamespot.com/api/volumes/"
                f"?api_key={COMIC_VINE_KEY}&format=json"
                f"&filter=name:{vol_query}&limit=30"
                f"&field_list=id,name,start_year,count_of_issues,publisher,api_detail_url"
            )
            time.sleep(1.5)
            r1 = requests.get(filter_url, headers=headers, timeout=10).json()
            if r1.get('error') == 'OK':
                for v in r1.get('results', []):
                    vol_combined[v['id']] = v

            time.sleep(1.0)

            # Pass 1b: exact search endpoint
            search_url = (
                f"https://comicvine.gamespot.com/api/search/"
                f"?api_key={COMIC_VINE_KEY}&format=json"
                f"&resources=volume&query={vol_query}&limit=20"
            )
            r2 = requests.get(search_url, headers=headers, timeout=10).json()
            if r2.get('error') == 'OK':
                for v in r2.get('results', []):
                    vol_combined[v['id']] = v

            # Pass 1b-extra: try 'The {series}' (or drop leading 'The') so
            # 'Sensational She-Hulk' finds 'The Sensational She-Hulk' on CV
            for _the_variant in _the_variants(series)[1:]:
                if _the_variant.lower() != series.lower():
                    time.sleep(0.5)
                    _tq = urllib.parse.quote(_the_variant)
                    _tr = requests.get(
                        f"https://comicvine.gamespot.com/api/volumes/"
                        f"?api_key={COMIC_VINE_KEY}&format=json"
                        f"&filter=name:{_tq}&limit=20"
                        f"&field_list=id,name,start_year,count_of_issues,publisher,api_detail_url",
                        headers=headers, timeout=10
                    ).json()
                    if _tr.get('error') == 'OK':
                        for v in _tr.get('results', []):
                            vol_combined[v['id']] = v

            # Pass 1c: for TPBs search additional queries to catch named volumes
            if subtitle:
                time.sleep(1.0)
                full_query = urllib.parse.quote(f"{series} {subtitle}")
                r3 = requests.get(
                    f"https://comicvine.gamespot.com/api/search/"
                    f"?api_key={COMIC_VINE_KEY}&format=json"
                    f"&resources=volume&query={full_query}&limit=10",
                    headers=headers, timeout=10
                ).json()
                if r3.get('error') == 'OK':
                    for v in r3.get('results', []):
                        vol_combined[v['id']] = v
                # Pass 1d: 'Book N' or 'omnibus/deluxe' filenames →
                # also try 'series deluxe' and 'series omnibus'
                for extra_kw in ('deluxe', 'omnibus'):
                    triggers = [
                        re.match(r'(?i)^book\s*\d+$', subtitle),
                        extra_kw in subtitle.lower(),
                    ]
                    if any(triggers):
                        time.sleep(0.8)
                        eq = urllib.parse.quote(f"{series} {extra_kw}")
                        r4 = requests.get(
                            f"https://comicvine.gamespot.com/api/search/"
                            f"?api_key={COMIC_VINE_KEY}&format=json"
                            f"&resources=volume&query={eq}&limit=10",
                            headers=headers, timeout=10
                        ).json()
                        if r4.get('error') == 'OK':
                            for v in r4.get('results', []):
                                vol_combined[v['id']] = v

            vol_results = list(vol_combined.values())
            if vol_results:
                # Score every candidate and pick the best one
                vol_results.sort(
                    key=lambda v: _score_volume(v, series, issue, year_str, subtitle, vol_num),
                    reverse=True
                )
                target_vol_id = vol_results[0]['id']

            # STEP 2: EXACT ISSUE MATCH
            if target_vol_id:
                issue_filter = f"volume:{target_vol_id}"
                if issue:
                    issue_filter += f",issue_number:{issue}"
                    
                issue_url = f"https://comicvine.gamespot.com/api/issues/?api_key={COMIC_VINE_KEY}&format=json&filter={urllib.parse.quote(issue_filter)}&field_list=id,name,issue_number,cover_date,volume,api_detail_url,page_count,image,language"
                
                time.sleep(1.5)
                issue_response = requests.get(issue_url, headers=headers, timeout=10)
                issue_data = issue_response.json()
                
                if issue_data.get('error') == 'OK' and issue_data.get('number_of_total_results', 0) > 0:
                    final_results = issue_data['results']
            
            # STEP 3: FUZZY ISSUE SEARCH
            # For TPBs: search specifically by subtitle to surface the TPB issue record.
            # For regular issues: only run as fallback if step 2 found nothing.
            if parsed.get('is_tpb'):
                tpb_query = urllib.parse.quote(
                    f"{series} {subtitle}".strip() if subtitle else series
                )
                tpb_url = f"https://comicvine.gamespot.com/api/search/?api_key={COMIC_VINE_KEY}&format=json&resources=issue&query={tpb_query}&limit=15&field_list=id,name,issue_number,cover_date,volume,api_detail_url,page_count,image,language"
                time.sleep(1.5)
                r3 = requests.get(tpb_url, headers=headers, timeout=10).json()
                if r3.get('error') == 'OK':
                    existing_ids = {r['id'] for r in final_results}
                    for r in r3.get('results', []):
                        if r['id'] not in existing_ids:
                            final_results.append(r)
            elif not final_results:
                search_url = f"https://comicvine.gamespot.com/api/search/?api_key={COMIC_VINE_KEY}&format=json&resources=issue&query={urllib.parse.quote(self.query)}&limit=10&field_list=id,name,issue_number,cover_date,volume,api_detail_url,page_count,image,language"
                time.sleep(1.5)
                response = requests.get(search_url, headers=headers, timeout=10)
                fuzzy_data = response.json()
                if fuzzy_data.get('error') == 'OK':
                    existing_ids = {r['id'] for r in final_results}
                    for r in fuzzy_data.get('results', []):
                        if r['id'] not in existing_ids:
                            final_results.append(r)

        except Exception as e:
            print(f"Manual Search Error: {e}")

        # Sort so the best match is first in the dialog
        def _score_issue(r):
            score = 0
            vol = r.get('volume', {}) or {}
            vol_name   = str(vol.get('name') or '').lower()
            issue_name = str(r.get('name') or '').lower()
            issue_num  = str(r.get('issue_number') or '')

            # Penalise non-English issues — kills foreign-language editions
            lang = str(r.get('language') or '').lower()
            if lang and lang != 'english':              score -= 80

            _vn = _norm_vol_name(vol_name)
            _wn = _norm_vol_name(series)
            if _vn and _vn == _wn:                         score += 50
            elif _wn and _wn in _vn:                       score += 25
            elif _wn and _vn in _wn:                       score += 15
            if year_str:
                result_year = str(r.get('cover_date', ''))[:4]
                if result_year == year_str:         score += 25
                elif result_year and result_year != year_str: score -= 20

            if parsed.get('is_tpb'):
                # Lower vol bonus for TPBs — subtitle/page signals are dominant
                if target_vol_id and str(vol.get('id', '')) == str(target_vol_id): score += 30
                if re.search(r'\bvol\.?\s*\d', issue_name, re.I):    score += 200
                if subtitle and subtitle.lower() in issue_name:       score += 150
                if vol_num and issue_num == vol_num:                   score += 100
                try:
                    if int(r.get('page_count') or 0) > 100:           score += 120
                except (ValueError, TypeError): pass
                try:
                    n = int(issue_num)
                    if n > 50:   score -= 80
                    elif n > 20: score -= 40
                except (ValueError, TypeError): pass
            else:
                # Strong vol bonus for regular issues — the matched volume is very likely right
                if target_vol_id and str(vol.get('id', '')) == str(target_vol_id): score += 60
                if issue and issue_num == issue:                       score += 80
                if subtitle and subtitle.lower() in issue_name:       score += 40

            return score

        final_results.sort(key=_score_issue, reverse=True)

        # Send the final list of issues directly to your UI!
        self.results_ready.emit(final_results)

