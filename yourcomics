        self.ai_btn.setEnabled(True)
        self.status_label.setText(f"✅ AI found {len(items)} items!")
        
        for book in items:
            series = book.get('series', '')
            issue = book.get('issue', '')
            year = book.get('year', '')
            
            # THE FIX: Only add the # symbol if an issue number actually exists!
            display = f"{series} #{issue}" if issue else series
            
            if year: display += f" ({year})"
                
            item = QListWidgetItem(f"✨ {display}") 
            item.setData(Qt.ItemDataRole.UserRole, {"series": series, "issue": issue, "year": year})
